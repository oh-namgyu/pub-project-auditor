# Copy to .env and fill in. None of these have defaults that point to your home dir.

# REQUIRED: Absolute path to the directory containing the repositories you want to audit.
# Example: /Users/alice/code  or  /home/alice/repos
AUDITOR_REPOS_DIR=/absolute/path/to/your/repos

# OPTIONAL: Comma-separated list of GitHub usernames/orgs you consider "yours".
# Repos whose origin URL contains any of these are kept; everything else is excluded.
# Leave empty to keep ALL local repos.
AUDITOR_OWNERS=

# OPTIONAL: Port for the web dashboard. Default 6020.
AUDITOR_PORT=6020

# OPTIONAL: Bind host. Default 127.0.0.1 (loopback only).
# WARNING: any value other than 127.0.0.1 / ::1 / localhost makes the
# dashboard network-reachable. AUDITOR_TOKEN is then REQUIRED.
AUDITOR_HOST=127.0.0.1

# REQUIRED iff AUDITOR_HOST is not loopback. Long random secret used as a
# Bearer token (Authorization: Bearer <token>) or ?token=<token> query param.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# AUDITOR_TOKEN=

# OPTIONAL: Path to the Claude Code CLI binary. If unset, PATH is searched.
# CLAUDE_BIN=/usr/local/bin/claude

# OPTIONAL: Claude model name. Default "sonnet".
# AUDITOR_MODEL=sonnet

# OPTIONAL: Per-task timeout in seconds. Default 1800.
# AUDITOR_TIMEOUT_SEC=1800

# OPTIONAL: Max number of concurrent audit jobs (queued + running). New
# POST /api/audit calls past this cap return HTTP 429. Default 2.
# AUDITOR_MAX_CONCURRENT=2

# OPTIONAL: Hard ceiling on total Claude cost (USD) per job. Once
# accumulated cost across this job's tasks exceeds the cap, remaining tasks
# are skipped (status: cancelled) with a budget-overrun error. Default
# unset = no cap.
# AUDITOR_COST_USD_MAX=1.00

# OPTIONAL: Claude tools allowlist passed via --tools. Default Read,Glob,Grep
# (read-only) contains prompt-injection blast radius from hostile target
# repos. Expand at your own risk.
# AUDITOR_TOOLS=Read,Glob,Grep

# OPTIONAL: Comma-separated extra env var names to pass through to the
# claude subprocess. The base allowlist already covers PATH/HOME/USER/LANG,
# LC_*, TERM, plus anything starting with ANTHROPIC_, CLAUDE_, AWS_BEDROCK_,
# GCP_VERTEX_. Use this only if claude needs a custom var not on that list.
# AUDITOR_ENV_PASSTHROUGH=

# OPTIONAL: Append-only JSONL audit log. One line per job on completion
# (timestamp, job_id, project, tasks, status, cost_usd, error). Unset = no
# log. Path is created on demand. Useful for billing / forensics.
# AUDITOR_AUDIT_LOG_PATH=~/.pub-auditor/audit.log

# OPTIONAL: Size-based rotation. When the active log file would exceed
# AUDITOR_AUDIT_LOG_MAX_BYTES (default 10 MiB), it's renamed to <path>.1
# and a fresh file is opened. Up to AUDITOR_AUDIT_LOG_BACKUPS (default 5)
# historical files are kept; the oldest is unlinked.
# AUDITOR_AUDIT_LOG_MAX_BYTES=10485760
# AUDITOR_AUDIT_LOG_BACKUPS=5

# OPTIONAL: Terminal-state jobs (done / cancelled / failed) older than
# this drop out of /api/audits and out of the in-memory store on the next
# request. Default 86400 (24h).
# AUDITOR_JOB_TTL_SECONDS=86400

# OPTIONAL: Sandbox/wrapper prefix prepended to the claude argv. Tokens are
# shlex-split. The operator owns wrapper correctness — we just chain it.
# Examples:
#   AUDITOR_CLAUDE_WRAPPER="nsjail -Mo --chroot /sandbox --"
#   AUDITOR_CLAUDE_WRAPPER="firejail --noprofile --net=none"
#   AUDITOR_CLAUDE_WRAPPER="bwrap --ro-bind / / --dev /dev"
# AUDITOR_CLAUDE_WRAPPER=
